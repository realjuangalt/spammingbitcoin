RECEIPT_SECRET=change-me-in-production
PUBLIC_API_BASE=http://127.0.0.1:8100
PUBLIC_STRATUM_HOST=pool.spammingbitcoin.com
PUBLIC_STRATUM_PORT=3333
ACCESS_ZERO_BITS=18
ACCESS_MAX_SECONDS=3

# ── Site network toggle (restart API after changing) ─────────────────────────
# testnet | mainnet
NETWORK=testnet

UPSTREAM_MODE=reseller
# Used when NETWORK=testnet
UPSTREAM_STRATUM_HOST=pool.xaxamining.com
UPSTREAM_STRATUM_PORT=3335
UPSTREAM_STRATUM_USER=
UPSTREAM_STRATUM_PASS=x
# Used when NETWORK=mainnet (host may be bare or stratum+tcp://…)
UPSTREAM_STRATUM_MAIN_HOST=stratum.braiins.com
UPSTREAM_STRATUM_MAIN_PORT=3333
UPSTREAM_STRATUM_MAIN_USER=account.worker
UPSTREAM_STRATUM_MAIN_PASS=x

STRATUM_LISTEN_HOST=0.0.0.0
STRATUM_LISTEN_PORT=3333
STRATUM_EDGE_DIFFICULTY=1024
# Optional: credit unknown Stratum workers to this Site id (set after you enroll a demo Site)
# STRATUM_DEFAULT_SITE_ID=pub_…
DOMAIN=spammingbitcoin.com

# Blink custodial Lightning (pay Sites at their LN address)
BLINK_API_URL=https://api.blink.sv/graphql
BLINK_API_KEY=
BLINK_WALLET_ID=
PAYOUT_MIN_SATS=1000
# Pool commission disclosed at signup (Sites receive 100 − this percent)
POOL_FEE_PERCENT=21
# Source repo — GitHub link in site nav (optional)
PUBLIC_GITHUB_REPO=https://github.com/realjuangalt/spammingbitcoin
# PUBLIC_SIGNUP_BASE=https://signup.spammingbitcoin.com
